<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.app.client.controller.UploadController"
            stylesheets="@css/style.css"
            styleClass="upload-root">

    <children>

        <!-- Wybierz pliki -->
        <Button fx:id="chooseButton"
                text="Wybierz pliki…"
                layoutX="14" layoutY="14"
                onAction="#onChooseFiles"
                styleClass="btn btn-aqua"/>

        <!-- Start Upload -->
        <Button fx:id="uploadButton"
                text="Start Upload"
                layoutX="130" layoutY="14"
                onAction="#onStartUpload"
                disable="true"
                styleClass="btn btn-warning"/>

        <!-- Lista plików -->
        <ScrollPane layoutX="14" layoutY="50"
                    prefWidth="472" prefHeight="336"
                    styleClass="scroll">
            <content>
                <VBox fx:id="filesContainer"
                      spacing="8"
                      padding="10"
                      styleClass="card"/>
            </content>
        </ScrollPane>

    </children>
</AnchorPane>