<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<VBox stylesheets="@css/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.app.client.controller.ClientWindowController">

    <!-- MAIN CONTENT AREA -->
    <HBox spacing="10">
        <!-- LEFT PANEL -->
        <VBox prefHeight="0.0" prefWidth="82.0" spacing="10" styleClass="card">
             <Button onAction="#onUpload" prefHeight="30.0" prefWidth="62.0" styleClass="btn btn-aqua" text="Upload" />
            <!-- Remove and Refresh buttons removed -->

             <Button onAction="#onDownload" prefHeight="30.0" prefWidth="60.0" styleClass="btn btn-warning" text="Download" />
         <Pane prefHeight="200.0" prefWidth="200.0" />
   
                 <Button onAction="#onLogout" prefHeight="28.0" prefWidth="67.0" styleClass="btn btn-danger" text="Logout" VBox.vgrow="NEVER" />

        </VBox>

        <!-- CENTER PANEL -->
        <VBox spacing="10" styleClass="card" VBox.vgrow="ALWAYS">
           <Label fx:id="welcomeLabel" prefHeight="15.0" prefWidth="551.0" />

            <!-- TABLE -->
            <TableView fx:id="fileTable" styleClass="table" VBox.vgrow="ALWAYS">

                <columns>
                    <TableColumn fx:id="filenameColumn" prefWidth="250" text="Filename" />

                    <TableColumn fx:id="sizeColumn" prefWidth="120" text="Size" />

                    <TableColumn fx:id="lastModifiedColumn" prefWidth="180" text="Last Modified" />
                </columns>

            </TableView>

            <!-- ACTION BUTTONS -->
            <!-- Share functionality removed -->


            <!-- PROGRESS BAR CONTAINER -->
            <VBox fx:id="progressContainer" spacing="5" />
        </VBox>

    </HBox>

</VBox>
